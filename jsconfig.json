{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["ES2015", "DOM"],
    "types": [],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "app/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "app/config.local.js",
    "app/source",
    "dist",
    "node_modules"
  ]
}
